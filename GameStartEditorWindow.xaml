<Window x:Class="SpaceHavenEditor2.GameStartEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Start &amp; Difficulty Editor" Height="950" Width="1200" 
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="WhiteSmoke"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="LightGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" Direction="270" Color="Gray" Opacity="0.3" BlurRadius="5"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF009AFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="Gray"/>
                                <Setter Property="Foreground" Value="DarkGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="LightGray"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="LightGray"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="True"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- File Load Section -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="File" FontSize="16" FontWeight="Bold" Grid.Column="0"/>
                    <TextBlock x:Name="txtUnsavedIndicator" 
                           Text="⚠ Unsaved Changes - Click 'Save Changes' to save!" 
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#FFFF0000" 
                           Background="#FFFFE4B5"
                           Padding="10,5"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Grid.Column="1"
                           Visibility="Collapsed">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="2" Direction="270" Color="Black" Opacity="0.5" BlurRadius="3"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnLoadFile" Content="Load File" Width="100" Height="30" 
                            Click="btnLoadFile_Click" Style="{StaticResource ModernButtonStyle}"/>
                    <TextBlock x:Name="txtFilePath" Text="No file loaded" Margin="10,0,0,0" 
                               VerticalAlignment="Center" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Settings Section -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" x:Name="settingsCard" IsEnabled="False">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Game Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <GroupBox Header="Relationships" Margin="0,0,0,10">
                        <StackPanel>
                            <CheckBox x:Name="chkEnemiesEnabled" Content="Enemies Enabled" Margin="0,5"
                                      Checked="chkEnemiesEnabled_Checked" Unchecked="chkEnemiesEnabled_Unchecked"/>
                            <CheckBox x:Name="chkFriendsEnabled" Content="Friends Enabled" Margin="0,5"
                                      Checked="chkFriendsEnabled_Checked" Unchecked="chkFriendsEnabled_Unchecked"/>
                            <CheckBox x:Name="chkLoversEnabled" Content="Lovers Enabled" Margin="0,5"
                                      Checked="chkLoversEnabled_Checked" Unchecked="chkLoversEnabled_Unchecked"/>
                        </StackPanel>
                    </GroupBox>
                    <CheckBox x:Name="chkSandbox" Content="Sandbox Mode" Margin="0,5"
                              Checked="chkSandbox_Checked" Unchecked="chkSandbox_Unchecked"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Crew &amp; Resource Limits" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <GroupBox Header="Crew Settings" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="Crew Count:" Width="120" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtCrew" Width="100" Height="25" TextChanged="txtCrew_TextChanged"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="Max Crew:" Width="120" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtMaxCrew" Width="100" Height="25" TextChanged="txtMaxCrew_TextChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Resource Limits">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="Max Resources:" Width="120" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtMaxResources" Width="100" Height="25" TextChanged="txtMaxResources_TextChanged"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="Max Items:" Width="120" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtMaxItems" Width="100" Height="25" TextChanged="txtMaxItems_TextChanged"/>
                            </StackPanel>
                            <CheckBox x:Name="chkHangarsPopulated" Content="Hangars Populated" Margin="0,10,0,0"
                                      Checked="chkHangarsPopulated_Checked" Unchecked="chkHangarsPopulated_Unchecked"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Resources and Items Tabs -->
        <TabControl Grid.Row="3" Margin="0,0,0,10">
            <TabItem Header="Resources">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Resources" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <DataGrid x:Name="dgResources" Style="{StaticResource ModernDataGridStyle}" 
                                  Height="250" SelectionChanged="dgResources_SelectionChanged"
                                  SelectionMode="Extended" CanUserDeleteRows="False"
                                  CellEditEnding="dgResources_CellEditEnding">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}, Mode=TwoWay}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="ID" Binding="{Binding ElementId}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Add Item:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox x:Name="cmbAddResource" Width="300" Height="30" 
                                      SelectedValuePath="ItemId" Margin="5,0,10,0">
                                <ComboBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12" 
                                                           Foreground="#FF007ACC" Margin="5,0,0,0"/>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ComboBox.GroupStyle>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ItemName}" Margin="10,0,0,0"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="Quantity:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                            <TextBox x:Name="txtAddResourceQuantity" Width="60" Height="30" Text="1" VerticalContentAlignment="Center"/>
                            <Button x:Name="btnAddResource" Content="Add" Width="100" Height="30" 
                                    Click="btnAddResource_Click" Style="{StaticResource ModernButtonStyle}" Margin="10,0,10,0"/>
                            <Button x:Name="btnDeleteSelectedResources" Content="Delete Selected" Width="130" Height="30" 
                                    Click="btnDeleteSelectedResources_Click" Style="{StaticResource ModernButtonStyle}" 
                                    Background="IndianRed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>
            <TabItem Header="Items">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Items (Weapons, Armor, Medical, etc.)" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <DataGrid x:Name="dgItems" Style="{StaticResource ModernDataGridStyle}" 
                                  Height="250" SelectionChanged="dgItems_SelectionChanged"
                                  SelectionMode="Extended" CanUserDeleteRows="False"
                                  CellEditEnding="dgItems_CellEditEnding">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}, Mode=TwoWay}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="ID" Binding="{Binding ElementId}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Add Item:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox x:Name="cmbAddItem" Width="300" Height="30" 
                                      SelectedValuePath="ItemId" Margin="5,0,10,0">
                                <ComboBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12" 
                                                           Foreground="#FF007ACC" Margin="5,0,0,0"/>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ComboBox.GroupStyle>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ItemName}" Margin="10,0,0,0"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="Quantity:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                            <TextBox x:Name="txtAddItemQuantity" Width="60" Height="30" Text="1" VerticalContentAlignment="Center"/>
                            <Button x:Name="btnAddItem" Content="Add" Width="100" Height="30" 
                                    Click="btnAddItem_Click" Style="{StaticResource ModernButtonStyle}" Margin="10,0,10,0"/>
                            <Button x:Name="btnDeleteSelectedItems" Content="Delete Selected" Width="130" Height="30" 
                                    Click="btnDeleteSelectedItems_Click" Style="{StaticResource ModernButtonStyle}" 
                                    Background="IndianRed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
        
        <!-- Save Button -->
        <Border Grid.Row="5" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <Button x:Name="btnSaveChanges" Content="Save Changes" Width="150" Height="35" 
                        Click="btnSaveChanges_Click" Style="{StaticResource ModernButtonStyle}"
                        HorizontalAlignment="Right" IsEnabled="False"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
