<Window x:Class="SpaceHavenEditor2.BlueprintManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpaceHavenEditor2"
        mc:Ignorable="d"
        Title="Space Haven Ship Blueprint Manager" Height="550" Width="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="WhiteSmoke"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" Direction="270" Color="#CCCCCC" Opacity="0.2" BlurRadius="10"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF009AFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="Gray"/>
                                <Setter Property="Foreground" Value="DarkGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilePathTextStyle" TargetType="TextBlock">
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Background="#FFEFEFEF" CornerRadius="8" BorderBrush="#FFABADB3" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Height="30" Background="DimGray" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                                VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"
                                Foreground="White" FontWeight="SemiBold"/>
                    <Button Content="X" HorizontalAlignment="Right" VerticalAlignment="Center"
                             Width="30" Height="25" Margin="0,0,5,0" FontWeight="Bold"
                             Style="{StaticResource ModernButtonStyle}" Background="IndianRed"
                             Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Export Ship Blueprint" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnSelectSourceSave" Content="Select Source Save ('game')..." Width="200" Style="{StaticResource ModernButtonStyle}" Click="btnSelectSourceSave_Click"/>
                        <TextBlock Grid.Column="1" x:Name="txtSourceSavePath" Text="(No source save selected)" Style="{StaticResource FilePathTextStyle}"/>
                    </Grid>
                    <TextBlock Text="Select Ship to Export:" Margin="0,5,0,5"/>
                    <ComboBox x:Name="cmbShipsToExport" Height="25" Margin="0,0,0,10" DisplayMemberPath="Sname" SelectedValuePath="Sid" IsEnabled="False" SelectionChanged="cmbShipsToExport_SelectionChanged"/>
                    <TextBlock Text="Export Mode:" Margin="0,5,0,5" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="chkExportAsBlueprint" Content="Export as Blueprint (unbuilt)" IsChecked="True" Margin="0,0,15,0" GroupName="ExportMode"/>
                        <RadioButton x:Name="chkExportAsBuilt" Content="Export as Built Ship" IsChecked="False" GroupName="ExportMode"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnExportBlueprint" Content="Export Selected Ship Blueprint" Width="220" Style="{StaticResource ModernButtonStyle}" Click="btnExportBlueprint_Click" IsEnabled="False"/>
                        <Button x:Name="btnDeleteSourceShip" Content="Delete Selected Ship" Width="170" Style="{StaticResource ModernButtonStyle}" Background="IndianRed" Click="btnDeleteSourceShip_Click" IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Import Ship Blueprint" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnSelectBlueprintFile" Content="Select Blueprint File (.xml)..." Width="200" Style="{StaticResource ModernButtonStyle}" Click="btnSelectBlueprintFile_Click"/>
                        <TextBlock Grid.Column="1" x:Name="txtBlueprintFilePath" Text="(No blueprint selected)" Style="{StaticResource FilePathTextStyle}"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnSelectTargetSave" Content="Select Target Save ('game')..." Width="200" Style="{StaticResource ModernButtonStyle}" Click="btnSelectTargetSave_Click"/>
                        <TextBlock Grid.Column="1" x:Name="txtTargetSavePath" Text="(No target save selected)" Style="{StaticResource FilePathTextStyle}"/>
                    </Grid>
                    <CheckBox x:Name="chkImportAsBlueprint" Margin="0,0,0,10" Content="Import as Blueprint (keeps the hull plan; excludes facilities, crew, robots, and items)" IsChecked="False"/>
                    <Button x:Name="btnImportBlueprint" Content="Import Blueprint to Target Save" HorizontalAlignment="Center" Width="220" Style="{StaticResource ModernButtonStyle}" Click="btnImportBlueprint_Click" IsEnabled="False"/>
                </StackPanel>
            </Border>

            <StatusBar Grid.Row="4" VerticalAlignment="Bottom" Background="#FFE0E0E0">
                <StatusBarItem>
                    <TextBlock x:Name="txtStatus" Text="Ready"/>
                </StatusBarItem>
            </StatusBar>

        </Grid>
    </Border>
</Window>

