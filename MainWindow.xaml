                                        <TextBlock Text="Ship / Station:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="cmbStorageShip" Width="360" DisplayMemberPath="DisplayName"
