                                                    <DataGridTextColumn Header="Target" Binding="{Binding TargetName}" Width="300" IsReadOnly="True" />
                                                    <DataGridTextColumn Header="Friendship" Binding="{Binding Friendship, UpdateSourceTrigger=PropertyChanged}" Width="Auto" IsReadOnly="False"/>
                                                    <DataGridTextColumn Header="Attraction" Binding="{Binding Attraction, UpdateSourceTrigger=PropertyChanged}" Width="Auto" IsReadOnly="False"/>
                                                    <DataGridTextColumn Header="Compatibility" Binding="{Binding Compatibility, UpdateSourceTrigger=PropertyChanged}" Width="Auto" IsReadOnly="False"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <WrapPanel Grid.Row="2" Margin="0,8,0,0">
