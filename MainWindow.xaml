                                                <DataGridTextColumn Header="Item ID" Binding="{Binding ElementId}" Width="80"/>
                                                <DataGridTextColumn Header="Locations" Binding="{Binding Locations}" Width="2*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
