                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="360"/>
                                        <ColumnDefinition Width="25"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="5" Text="Create New Crew Member" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Grid.Row="1" Text="Target ship / station:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbNewCrewShip" DisplayMemberPath="DisplayName"
                                              SelectionChanged="cmbNewCrewShip_SelectionChanged"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Template crew:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" x:Name="cmbNewCrewTemplate" DisplayMemberPath="CharacterName"
                                              SelectedValuePath="CharacterEntityId"/>
                                    <TextBlock Grid.Row="2" Text="New crew name:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtEmbeddedNewCrewName" Text="New Recruit"
                                             Margin="0,10,0,0" Style="{StaticResource ModernTextBoxStyle}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2"
                                               Text="The selected crew member supplies required XML structure. Conditions, relationships, and bed assignment are cleared."
                                               Margin="0,10,0,0" FontStyle="Italic" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <TabControl Grid.Row="1" Style="{StaticResource ModernTabControlStyle}">
                                <TabItem Header="Attributes">
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Button Grid.Row="0" Content="Set All Attributes to 10" Width="185" HorizontalAlignment="Left"
                                                    Click="btnSetEmbeddedNewAttributes_Click" Style="{StaticResource ModernButtonStyle}"/>
                                            <DataGrid Grid.Row="1" x:Name="dgvEmbeddedNewAttributes" Margin="0,8,0,0"
                                                      Style="{StaticResource ModernDataGridStyle}"
                                                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="80"/>
                                                    <DataGridTextColumn Header="Attribute" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="100"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>
                                </TabItem>
                                <TabItem Header="Skills">
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Button Grid.Row="0" Content="Set All Skills to 10" Width="170" HorizontalAlignment="Left"
                                                    Click="btnSetEmbeddedNewSkills_Click" Style="{StaticResource ModernButtonStyle}"/>
                                            <DataGrid Grid.Row="1" x:Name="dgvEmbeddedNewSkills" Margin="0,8,0,0"
                                                      Style="{StaticResource ModernDataGridStyle}"
                                                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="80"/>
                                                    <DataGridTextColumn Header="Skill" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                                                    <DataGridTextColumn Header="Level" Binding="{Binding Value}" Width="100"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>
                                </TabItem>
                                <TabItem Header="Traits">
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Available Traits" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <ComboBox x:Name="cmbEmbeddedAvailableTraits" DisplayMemberPath="Value" SelectedValuePath="Key"/>
                                                <Button Content="Add Trait" Width="120" HorizontalAlignment="Left"
                                                        Click="btnAddEmbeddedNewTrait_Click" Style="{StaticResource ModernButtonStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Selected Traits" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <ListBox x:Name="lstEmbeddedNewTraits" Height="250" DisplayMemberPath="Name"/>
                                                <Button Content="Remove Selected" Width="140" HorizontalAlignment="Left" Background="IndianRed"
                                                        Click="btnRemoveEmbeddedNewTrait_Click" Style="{StaticResource ModernButtonStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </TabItem>
                            </TabControl>

                            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="lblEmbeddedNewCrewStatus" VerticalAlignment="Center" FontStyle="Italic"/>
                                    <Button Grid.Column="1" Content="Create Crew Member" Width="180"
                                            Click="btnCreateEmbeddedCrew_Click" Style="{StaticResource ModernButtonStyle}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem x:Name="navBulkOperations" Header="Bulk Operations" Tag="&#xE8B7;">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Nested TabControl as header -->
                                <RowDefinition Height="*"/>
                                <!-- Sub-tab content -->
                            </Grid.RowDefinitions>

                            <!-- Nested TabControl as Header -->
                            <TabControl Grid.Row="0" Style="{StaticResource NestedTabControlStyle}" Margin="0,0,0,10" SelectionChanged="BulkTabControl_SelectionChanged">
                                <TabItem Header="Add Bulk Crew"/>
                                <TabItem Header="Bulk Character Stats"/>
                                <TabItem Header="Bulk Traits"/>
                                <TabItem Header="Bulk Schedules"/>
                                <TabItem Header="Bulk Recovery"/>
                                <TabItem Header="Bulk Loadouts"/>
                            </TabControl>

                            <!-- Sub-Tab Content in Detached Card -->
                            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Margin="5">
                                    <!-- Bulk Crew Content -->
                                    <StackPanel x:Name="bulkCrewPanel">
                                        <TextBlock Text="Add Multiple Crew Members" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <Label Content="Template Crew:" VerticalAlignment="Center" FontSize="12"/>
                                            <ComboBox x:Name="cmbTemplateCrew" Width="200" VerticalAlignment="Center"
                                                      DisplayMemberPath="CharacterName" SelectedValuePath="CharacterEntityId"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <Label Content="Number to Add:" VerticalAlignment="Center" FontSize="12"/>
                                            <TextBox x:Name="txtBulkCrewAmount" Width="50" VerticalAlignment="Center" Text="10" Style="{StaticResource ModernTextBoxStyle}"/>
                                            <Button x:Name="btnBulkAddCrew" Content="Add Crew" Margin="10,0,0,0" Click="BtnBulkAddCrew_Click" Style="{StaticResource ModernButtonStyle}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="lblBulkStatus" Text="" Margin="0,5,0,0" FontSize="12"/>
                                    </StackPanel>
                                    
                                    <!-- Bulk Character Stats Content (Combined Attributes and Skills) -->
                                    <StackPanel x:Name="bulkStatsPanel" Visibility="Collapsed">
                                        <!-- Attributes Section -->
                                        <TextBlock Text="Set Attributes for All Characters" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <Label Content="Attribute Value (1-10):" VerticalAlignment="Center" FontSize="12"/>
                                            <TextBox x:Name="txtBulkAttributeValue" Width="50" VerticalAlignment="Center" Text="5" Style="{StaticResource ModernTextBoxStyle}"/>
                                            <Button x:Name="btnBulkSetAttributes" Content="Set All Attributes" Margin="10,0,0,0" Click="btnBulkSetAttributes_Click" Style="{StaticResource ModernButtonStyle}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="lblBulkAttributeStatus" Text="" Margin="0,5,0,0" FontSize="12"/>
                                        
                                        <!-- Separator -->
                                        <Separator Margin="0,20,0,20" Background="LightGray"/>
                                        
                                        <!-- Skills Section -->
                                        <TextBlock Text="Set Skills for All Characters" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <Label Content="Current Skill Level (1-10):" VerticalAlignment="Center" FontSize="12"/>
                                            <TextBox x:Name="txtBulkSkillValue" Width="50" VerticalAlignment="Center" Text="5" Style="{StaticResource ModernTextBoxStyle}"/>
                                            <Button x:Name="btnBulkSetSkills" Content="Set All Current Skills" Margin="10,0,0,0" Click="btnBulkSetSkills_Click" Style="{StaticResource ModernButtonStyle}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <Label Content="Max Skill Level (1-10):" VerticalAlignment="Center" FontSize="12"/>
                                            <TextBox x:Name="txtBulkSkillMaxValue" Width="50" VerticalAlignment="Center" Text="10" Style="{StaticResource ModernTextBoxStyle}"/>
                                            <Button x:Name="btnBulkSetMaxSkills" Content="Set All Max Skills" Margin="10,0,0,0" Click="btnBulkSetMaxSkills_Click" Style="{StaticResource ModernButtonStyle}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <Button x:Name="btnBulkSetSkillsMax" Content="Set All Current Skills to Their Max Level" Width="280" HorizontalAlignment="Left" Click="btnBulkSetSkillsMax_Click" Style="{StaticResource ModernButtonStyle}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="lblBulkSkillStatus" Text="" Margin="0,5,0,0" FontSize="12"/>
                                    </StackPanel>

                                    <StackPanel x:Name="bulkTraitsPanel" Visibility="Collapsed">
                                        <TextBlock Text="Bulk Traits for Current Ship / Station" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="lblBulkTraitsShip" Text="Select a ship or station in Crew Editor."
                                                   FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <TextBlock Text="Select one or more traits to add. Existing traits are skipped, not duplicated."
                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <ListBox x:Name="lstBulkTraits" Height="260" DisplayMemberPath="Value"
                                                 SelectionMode="Extended"/>
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Content="Add Selected Trait(s) to Ship Crew" Width="250"
                                                    Click="btnBulkAddTraits_Click" Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Clear All Traits from Ship Crew" Width="240"
                                                    Click="btnBulkClearTraits_Click" Style="{StaticResource ModernButtonStyle}"/>
                                        </WrapPanel>
                                        <TextBlock x:Name="lblBulkTraitsStatus" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel x:Name="bulkSchedulePanel" Visibility="Collapsed">
                                        <TextBlock Text="Assign Global Schedule to Selected Crew" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock Text="Crew shown here belong to the currently selected ship or station." FontStyle="Italic" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="Select All" Width="110" Height="32" Padding="8,2" Click="btnBulkScheduleSelectAll_Click" Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Clear" Width="110" Height="32" Padding="8,2" Margin="8,0,0,0" Click="btnBulkScheduleClear_Click" Style="{StaticResource ModernButtonStyle}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="lblBulkScheduleCounts" FontWeight="SemiBold" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                        <ListBox x:Name="lstBulkScheduleCrew" Height="280">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="3" Width="500">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="180"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding CurrentSchedule}" VerticalAlignment="Center" FontStyle="Italic"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="Global schedule:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <ComboBox x:Name="cmbBulkGlobalSchedule" Width="190" DisplayMemberPath="Value" SelectedValuePath="Key"/>
                                            <Button Content="Apply to Checked Crew" Width="190" Margin="10,0,0,0"
                                                    Click="btnApplyBulkGlobalSchedule_Click" Style="{StaticResource ModernButtonStyle}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="lblBulkScheduleStatus" Margin="0,8,0,0"/>
                                    </StackPanel>

                                    <StackPanel x:Name="bulkRecoveryPanel" Visibility="Collapsed">
                                        <TextBlock Text="Recover Selected Crew" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock Text="Crew shown here belong to the ship or station selected in Crew Editor. Restore keeps enhanced health values, and Full Recovery also clears all conditions."
                                                   FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="Select All" Width="110" Height="32" Padding="8,2"
                                                    Click="btnBulkRecoverySelectAll_Click" Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Clear" Width="110" Height="32" Padding="8,2" Margin="8,0,0,0"
                                                    Click="btnBulkRecoveryClear_Click" Style="{StaticResource ModernButtonStyle}"/>
                                        </StackPanel>
                                        <ListBox x:Name="lstBulkRecoveryCrew" Height="300">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="3" Width="500">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Content="Restore Checked Crew" Width="180"
                                                    Click="btnRestoreBulkCrew_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Full Recovery for Checked Crew" Width="225"
                                                    Click="btnFullRecoveryBulkCrew_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Restore All Active Player Crew Vitals" Width="245"
                                                    Click="btnRestoreAllCrew_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Full Recovery for All Active Player Crew" Width="285"
                                                    Click="btnFullRecoveryAllCrew_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                        </WrapPanel>
                                        <TextBlock x:Name="lblBulkRecoveryStatus" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Grid x:Name="bulkLoadoutPanel" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="310"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Named Loadout Configurations" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                            <ComboBox Grid.Row="1" x:Name="cmbBulkLoadoutTemplate" DisplayMemberPath="Name"
                                                      SelectionChanged="cmbBulkLoadoutTemplate_SelectionChanged" Margin="0,0,0,8"/>
                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="Headgear:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbTemplateHeadgear" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="1" Text="Armor:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbTemplateArmor" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="2" Text="Primary:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbTemplatePrimary" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="3" Text="Attachment:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                                                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbTemplateAttachment" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="4" Text="Secondary:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                                                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbTemplateSecondary" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="5" Text="Pocket 1:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                                                <ComboBox Grid.Row="5" Grid.Column="1" x:Name="cmbTemplatePocket1" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="6" Text="Pocket 2:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                                                <ComboBox Grid.Row="6" Grid.Column="1" x:Name="cmbTemplatePocket2" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="7" Text="Pocket 3:" VerticalAlignment="Center" Margin="0,3,6,3"/>
                                                <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cmbTemplatePocket3" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <CheckBox Grid.Row="8" Grid.ColumnSpan="2" x:Name="chkTemplateBestQualityArmor"
                                                          Content="Use best available armor quality" Margin="0,5,0,2"/>
                                                <CheckBox Grid.Row="9" Grid.ColumnSpan="2" x:Name="chkTemplateBestQualityPrimary"
                                                          Content="Use best available primary quality" Margin="0,2,0,2"/>
                                            </Grid>
                                            <WrapPanel Grid.Row="3" Margin="0,8,0,0">
                                                <Button Content="New" Width="72" Click="btnNewLoadoutTemplate_Click" Style="{StaticResource ModernButtonStyle}"/>
                                                <Button Content="Save" Width="72" Click="btnSaveLoadoutTemplate_Click" Style="{StaticResource ModernButtonStyle}"/>
                                                <Button Content="Rename" Width="82" Click="btnRenameLoadoutTemplate_Click" Style="{StaticResource ModernButtonStyle}"/>
                                                <Button Content="Delete" Width="72" Click="btnDeleteLoadoutTemplate_Click" Style="{StaticResource ModernButtonStyle}"/>
                                            </WrapPanel>
                                        </Grid>
                                        <Grid Grid.Column="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Apply Configuration to Crew" FontSize="14" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="1" Text="Crew shown here belong to the ship or station selected in Crew Editor."
                                                       FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                            <ListBox Grid.Row="2" x:Name="lstBulkLoadoutCrew">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="3" Width="500">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="250"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding CurrentLoadout}" VerticalAlignment="Center" FontStyle="Italic"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <WrapPanel Grid.Row="3" Margin="0,8,0,0">
                                                <Button Content="Select All" Width="110" Click="btnBulkLoadoutSelectAll_Click" Style="{StaticResource ModernButtonStyle}"/>
                                                <Button Content="Clear" Width="110" Click="btnBulkLoadoutClear_Click" Style="{StaticResource ModernButtonStyle}"/>
                                                <Button Content="Apply Template to Checked Crew" Width="235"
                                                        Click="btnApplyBulkLoadout_Click" Style="{StaticResource ModernButtonStyle}"/>
                                            </WrapPanel>
                                            <TextBlock Grid.Row="4" x:Name="lblBulkLoadoutStatus" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem x:Name="navScheduleDesigner" Header="Global Schedule Designer" Tag="&#xE787;">
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Global Schedules" Style="{StaticResource CardTitleStyle}"/>
                                    <ListBox Grid.Row="1" x:Name="lstGlobalScheduleDesigner"
                                             DisplayMemberPath="DisplayName"
                                             SelectionChanged="lstGlobalScheduleDesigner_SelectionChanged"/>
                                    <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                                        <Button Content="Create" Width="105" Click="btnCreateGlobalSchedule_Click"
                                                Style="{StaticResource ModernButtonStyle}"/>
                                        <Button Content="Duplicate" Width="105" Click="btnDuplicateGlobalSchedule_Click"
                                                Style="{StaticResource ModernButtonStyle}"/>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Schedule Designer" Style="{StaticResource CardTitleStyle}"/>
                                    <Grid Grid.Row="1" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Schedule name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" x:Name="txtGlobalScheduleName" Style="{StaticResource ModernTextBoxStyle}"/>
                                        <Button Grid.Column="2" Content="Rename" Width="105" Margin="10,0,0,0"
                                                Click="btnRenameGlobalSchedule_Click" Style="{StaticResource ModernButtonStyle}"/>
                                    </Grid>
                                    <DataGrid Grid.Row="2" x:Name="dgvGlobalScheduleDesigner" AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              Style="{StaticResource ModernDataGridStyle}"
                                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Hour" Binding="{Binding HourLabel}" Width="*" IsReadOnly="True"/>
                                            <DataGridTemplateColumn Header="Activity" Width="240">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.ScheduleActivities, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  DisplayMemberPath="Value" SelectedValuePath="Key"
                                                                  SelectedValue="{Binding Activity, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Grid Grid.Row="3" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="lblGlobalScheduleDesignerStatus" VerticalAlignment="Center"
                                                   FontStyle="Italic" TextWrapping="Wrap"/>
                                        <Button Grid.Column="1" Content="Apply Schedule Changes" Width="205"
                                                Click="btnApplyGlobalScheduleChanges_Click"
                                                Style="{StaticResource ModernButtonStyle}"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem x:Name="navFactions" Header="Factions" Tag="&#xE909;">
                        <Border Style="{StaticResource CardBorderStyle}" Margin="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="Faction Reputation" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Player-facing factions only. Edit a row, then click Apply Selected Faction."
                                               Margin="0,3,0,0" FontStyle="Italic"/>
                                </StackPanel>
                                <DataGrid Grid.Row="1" x:Name="dgvFactionReputation" AutoGenerateColumns="False"
                                          CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single"
                                          Style="{StaticResource ModernDataGridStyle}"
                                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Faction" Binding="{Binding FactionName}" Width="150" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Reputation" Binding="{Binding Relationship, UpdateSourceTrigger=PropertyChanged}" Width="85"/>
                                        <DataGridComboBoxColumn Header="Stance" Width="100"
                                                                SelectedItemBinding="{Binding Stance, UpdateSourceTrigger=PropertyChanged}"/>
                                        <DataGridTextColumn Header="Patience" Binding="{Binding Patience, UpdateSourceTrigger=PropertyChanged}" Width="75"/>
                                        <DataGridCheckBoxColumn Header="Trade" Binding="{Binding AccessTrade}" Width="60"/>
                                        <DataGridCheckBoxColumn Header="Ship" Binding="{Binding AccessShip}" Width="55"/>
                                        <DataGridCheckBoxColumn Header="Vision" Binding="{Binding AccessVision}" Width="60"/>
                                        <DataGridCheckBoxColumn Header="Services" Binding="{Binding AccessServices}" Width="70"/>
                                        <DataGridCheckBoxColumn Header="Hire" Binding="{Binding AccessHire}" Width="55"/>
                                        <DataGridTextColumn Header="Settlement Debt" Binding="{Binding SettlementDebt, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                                    <Button Content="Enemy Preset" Width="165" Height="34" Padding="8,2" Click="btnFactionEnemy_Click" Style="{StaticResource ModernButtonStyle}"/>
                                    <Button Content="Neutral Preset" Width="165" Height="34" Padding="8,2" Margin="8,0,0,0" Click="btnFactionNeutral_Click" Style="{StaticResource ModernButtonStyle}"/>
                                    <Button Content="Friendly Preset" Width="165" Height="34" Padding="8,2" Margin="8,0,0,0" Click="btnFactionFriendly_Click" Style="{StaticResource ModernButtonStyle}"/>
                                    <Button Content="Full Access" Width="165" Height="34" Padding="8,2" Margin="8,0,0,0" Click="btnFactionFullAccess_Click" Style="{StaticResource ModernButtonStyle}"/>
                                    <Button Content="Apply Selected Faction" Width="165" Height="34" Padding="8,2" Margin="8,0,0,0"
                                            Click="btnApplyFaction_Click" Style="{StaticResource ModernButtonStyle}"/>
                                </WrapPanel>
                                <TextBlock Grid.Row="3" x:Name="lblFactionStatus" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                    </TabItem>

                    <TabItem x:Name="navShipsHeader" Header="SHIPS AND STATIONS" Tag="SectionHeader" IsEnabled="False"
                             HeaderTemplate="{StaticResource NavigationSectionHeaderTemplate}"/>
                    <TabItem x:Name="navShipTransfer" Header="Ship Import and Export" Tag="&#xE8B5;">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Export Ship Blueprint" Style="{StaticResource CardTitleStyle}"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="btnSelectSourceSave" Content="Select Source Save ('game')..." Width="200" Style="{StaticResource ModernButtonStyle}"/>
                                            <TextBlock Grid.Column="1" x:Name="txtSourceSavePath" Text="(No source save selected)" FontStyle="Italic" Foreground="Gray" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="Select Ship to Export:" Margin="0,5,0,5"/>
                                        <ComboBox x:Name="cmbShipsToExport" Height="25" Margin="0,0,0,10" DisplayMemberPath="Sname" SelectedValuePath="Sid" IsEnabled="False"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button x:Name="btnExportBlueprint" Content="Export Selected Ship Blueprint" Width="220" Style="{StaticResource ModernButtonStyle}" IsEnabled="False"/>
                                            <Button x:Name="btnDeleteSourceShip" Content="Delete Selected Ship" Width="170" Style="{StaticResource ModernButtonStyle}" Background="IndianRed" IsEnabled="False"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Import Ship Blueprint" Style="{StaticResource CardTitleStyle}"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="btnSelectBlueprintFile" Content="Select Blueprint File (.xml)..." Width="200" Style="{StaticResource ModernButtonStyle}"/>
                                            <TextBlock Grid.Column="1" x:Name="txtBlueprintFilePath" Text="(No blueprint selected)" FontStyle="Italic" Foreground="Gray" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="btnSelectTargetSave" Content="Select Target Save ('game')..." Width="200" Style="{StaticResource ModernButtonStyle}"/>
                                            <TextBlock Grid.Column="1" x:Name="txtTargetSavePath" Text="(No target save selected)" FontStyle="Italic" Foreground="Gray" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <CheckBox x:Name="chkImportAsBlueprint" Margin="0,0,0,10" Content="Import as Blueprint (keeps the hull plan; excludes facilities, crew, robots, and items)" IsChecked="False"/>
                                        <Button x:Name="btnImportBlueprint" Content="Import Blueprint to Target Save" HorizontalAlignment="Center" Width="220" Style="{StaticResource ModernButtonStyle}" IsEnabled="False"/>
                                    </StackPanel>
                                </Border>

                                <StatusBar Grid.Row="3" VerticalAlignment="Bottom" Background="#292825" Foreground="#E9E4DC">
                                    <StatusBarItem>
                                        <TextBlock x:Name="txtBlueprintStatus" Text="Ready"/>
                                    </StatusBarItem>
                                </StatusBar>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="navAdvancedHeader" Header="ADVANCED" Tag="SectionHeader" IsEnabled="False"
                             HeaderTemplate="{StaticResource NavigationSectionHeaderTemplate}"/>

                    <TabItem x:Name="navGameStartHeader" Header="GAME START" Tag="SectionHeader" IsEnabled="False"
                             HeaderTemplate="{StaticResource NavigationSectionHeaderTemplate}"/>
            <TabItem x:Name="navGameStartEditor" Header="Game Start Editor" Tag="&#xE7C3;">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Instructions Card (Collapsible) -->
                        <Border Grid.Row="1" Style="{StaticResource DirectionsCardStyle}">
                            <Expander Header="Instructions" Style="{StaticResource DirectionsExpanderStyle}">
                                <StackPanel Style="{StaticResource DirectionsContentStyle}">
                                    <TextBlock Style="{StaticResource DirectionsTextStyle}">
                                        <Run Text="1. In Space Haven: Start Game, pick Game Mode, pick Difficulty, then save the difficulty file as a custom one"/>
                                        <LineBreak/>
                                        <Run Text="2. Click 'Load File' to open your custom Game Start XML file from the scenario directory"/>
                                        <LineBreak/>
                                        <Run Text="3. Modify game settings, crew limits, and resource/item quantities as needed"/>
                                        <LineBreak/>
                                        <Run Text="4. Use the Resources and Items tabs to add, edit, or delete resources and items"/>
                                        <LineBreak/>
                                        <Run Text="5. Click 'Save Changes' to save your modifications to the file"/>
                                        <LineBreak/>
                                        <Run Text="Note: Remember to click 'Save Changes' after making any modifications!" FontWeight="SemiBold" Foreground="#D39A55"/>
                                    </TextBlock>
                                </StackPanel>
                            </Expander>
                        </Border>
                        
                        <!-- File Load Section -->
                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="File" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CardTitleStyle}"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button x:Name="btnGameStartLoadFile" Content="Load File" Width="100" Height="30" 
                                            Click="btnGameStartLoadFile_Click" Style="{StaticResource ModernButtonStyle}"/>
                                    <Button x:Name="btnGameStartSetScenarioFolder" Content="Set Scenario Folder" Width="140" Height="30" 
                                            Click="btnGameStartSetScenarioFolder_Click" Style="{StaticResource ModernButtonStyle}" Margin="10,0,0,0"/>
                                    <TextBlock x:Name="txtGameStartFilePath" Text="No file loaded" Margin="10,0,0,0" 
                                               VerticalAlignment="Center" FontSize="12" Foreground="Gray"/>
                                </StackPanel>
                                <TextBlock x:Name="txtGameStartScenarioFolder" Text="" FontSize="11" Foreground="DarkGray" FontStyle="Italic" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Settings Section -->
                        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" x:Name="gameStartSettingsCard" IsEnabled="False">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Game Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <GroupBox Header="Relationships" Margin="0,0,0,10">
                                        <StackPanel>
                                            <CheckBox x:Name="chkGameStartEnemiesEnabled" Content="Enemies Enabled" Margin="0,5"
                                                      Checked="chkGameStartEnemiesEnabled_Checked" Unchecked="chkGameStartEnemiesEnabled_Unchecked"/>
                                            <CheckBox x:Name="chkGameStartFriendsEnabled" Content="Friends Enabled" Margin="0,5"
                                                      Checked="chkGameStartFriendsEnabled_Checked" Unchecked="chkGameStartFriendsEnabled_Unchecked"/>
                                            <CheckBox x:Name="chkGameStartLoversEnabled" Content="Lovers Enabled" Margin="0,5"
                                                      Checked="chkGameStartLoversEnabled_Checked" Unchecked="chkGameStartLoversEnabled_Unchecked"/>
                                        </StackPanel>
                                    </GroupBox>
                                    <CheckBox x:Name="chkGameStartSandbox" Content="Sandbox Mode" Margin="0,5"
                                              Checked="chkGameStartSandbox_Checked" Unchecked="chkGameStartSandbox_Unchecked"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Crew &amp; Resource Limits" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <GroupBox Header="Crew Settings" Margin="0,0,0,10">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <TextBlock Text="Crew Count:" Width="120" VerticalAlignment="Center"/>
                                                <TextBox x:Name="txtGameStartCrew" Width="100" Height="25" TextChanged="txtGameStartCrew_TextChanged"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <TextBlock Text="Max Crew:" Width="120" VerticalAlignment="Center"/>
                                                <TextBox x:Name="txtGameStartMaxCrew" Width="100" Height="25" TextChanged="txtGameStartMaxCrew_TextChanged"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                    <GroupBox Header="Resource Limits">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <TextBlock Text="Max Resources:" Width="120" VerticalAlignment="Center"/>
                                                <TextBox x:Name="txtGameStartMaxResources" Width="100" Height="25" TextChanged="txtGameStartMaxResources_TextChanged"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <TextBlock Text="Max Items:" Width="120" VerticalAlignment="Center"/>
                                                <TextBox x:Name="txtGameStartMaxItems" Width="100" Height="25" TextChanged="txtGameStartMaxItems_TextChanged"/>
                                            </StackPanel>
                                            <CheckBox x:Name="chkGameStartHangarsPopulated" Content="Hangars Populated" Margin="0,10,0,0"
                                                      Checked="chkGameStartHangarsPopulated_Checked" Unchecked="chkGameStartHangarsPopulated_Unchecked"/>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Resources and Items Tabs -->
                        <TabControl Grid.Row="5" Margin="0,0,0,10" Style="{StaticResource NestedTabControlStyle}">
                            <TabItem Header="Resources">
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="Resources" Style="{StaticResource CardTitleStyle}"/>
                                        <DataGrid x:Name="dgGameStartResources" Style="{StaticResource ModernDataGridStyle}" 
                                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                                                  Height="300" SelectionChanged="dgGameStartResources_SelectionChanged"
                                                  SelectionMode="Extended" CanUserDeleteRows="False" CanUserAddRows="False"
                                                  CellEditEnding="dgGameStartResources_CellEditEnding" 
                                                  PreviewMouseDown="dgGameStartResources_PreviewMouseDown"
                                                  Margin="0,0,0,10">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="" Width="40">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                      Checked="GameStartCheckBox_Checked"
                                                                      Unchecked="GameStartCheckBox_Unchecked"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Item Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="Auto" IsReadOnly="False"/>
                                                <DataGridTextColumn Header="Item ID" Binding="{Binding ElementId}" Width="Auto" IsReadOnly="True"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="Add Item:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <ComboBox x:Name="cmbGameStartAddResource" Width="300" Height="30" 
                                                      SelectedValuePath="ItemId" Margin="5,0,10,0">
                                                <ComboBox.GroupStyle>
                                                    <GroupStyle>
                                                        <GroupStyle.HeaderTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12" 
                                                                           Foreground="#FF007ACC" Margin="5,0,0,0"/>
                                                            </DataTemplate>
                                                        </GroupStyle.HeaderTemplate>
                                                    </GroupStyle>
                                                </ComboBox.GroupStyle>
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ItemName}" Margin="10,0,0,0"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="Quantity:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                                            <TextBox x:Name="txtGameStartAddResourceQuantity" Width="60" Height="30" Text="1" VerticalContentAlignment="Center"/>
                                            <Button x:Name="btnGameStartAddResource" Content="Add" Width="100" Height="30" 
                                                    Click="btnGameStartAddResource_Click" Style="{StaticResource ModernButtonStyle}" Margin="10,0,10,0"/>
                                            <Button x:Name="btnGameStartDeleteSelectedResources" Content="Delete Selected" Width="130" Height="30" 
                                                    Click="btnGameStartDeleteSelectedResources_Click" Style="{StaticResource ModernButtonStyle}" 
                                                    Background="IndianRed"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </TabItem>
                            <TabItem Header="Items">
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="Items (Weapons, Armor, Medical, etc.)" Style="{StaticResource CardTitleStyle}"/>
                                        <DataGrid x:Name="dgGameStartItems" Style="{StaticResource ModernDataGridStyle}" 
                                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                                                  Height="300" SelectionChanged="dgGameStartItems_SelectionChanged"
                                                  SelectionMode="Extended" CanUserDeleteRows="False" CanUserAddRows="False"
                                                  CellEditEnding="dgGameStartItems_CellEditEnding"
                                                  PreviewMouseDown="dgGameStartItems_PreviewMouseDown"
                                                  Margin="0,0,0,10">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="" Width="40">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                      Checked="GameStartCheckBox_Checked"
                                                                      Unchecked="GameStartCheckBox_Unchecked"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Item Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="Auto" IsReadOnly="False"/>
                                                <DataGridTextColumn Header="Item ID" Binding="{Binding ElementId}" Width="Auto" IsReadOnly="True"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="Add Item:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <ComboBox x:Name="cmbGameStartAddItem" Width="300" Height="30" 
                                                      SelectedValuePath="ItemId" Margin="5,0,10,0">
                                                <ComboBox.GroupStyle>
                                                    <GroupStyle>
                                                        <GroupStyle.HeaderTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12" 
                                                                           Foreground="#FF007ACC" Margin="5,0,0,0"/>
                                                            </DataTemplate>
                                                        </GroupStyle.HeaderTemplate>
                                                    </GroupStyle>
                                                </ComboBox.GroupStyle>
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ItemName}" Margin="10,0,0,0"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="Quantity:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                                            <TextBox x:Name="txtGameStartAddItemQuantity" Width="60" Height="30" Text="1" VerticalContentAlignment="Center"/>
                                            <Button x:Name="btnGameStartAddItem" Content="Add" Width="100" Height="30" 
                                                    Click="btnGameStartAddItem_Click" Style="{StaticResource ModernButtonStyle}" Margin="10,0,10,0"/>
                                            <Button x:Name="btnGameStartDeleteSelectedItems" Content="Delete Selected" Width="130" Height="30" 
                                                    Click="btnGameStartDeleteSelectedItems_Click" Style="{StaticResource ModernButtonStyle}" 
                                                    Background="IndianRed"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </TabItem>
                        </TabControl>
                        
                        <!-- Save Button -->
                        <Border Grid.Row="7" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <Button x:Name="btnGameStartSaveChanges" Content="Save Changes" Width="150" Height="35" 
                                        Click="btnGameStartSaveChanges_Click" Style="{StaticResource ModernButtonStyle}"
                                        HorizontalAlignment="Right" IsEnabled="False"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="navLegacyBlueprint" Header="Blueprint Manager" Visibility="Collapsed">
                <TabItem.ContentTemplate>
                    <DataTemplate>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" CornerRadius="5,5,0,0" Margin="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#2A2926" Offset="0"/>
                                    <GradientStop Color="#49443E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Direction="270" Color="Black" Opacity="0.4" BlurRadius="5"/>
                            </Border.Effect>
                            <TextBlock Text="Ship Blueprint Manager"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,10"/>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Export Ship Blueprint" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="btnSelectSourceSave" Content="Select Source Save ('game')..." Width="200" Style="{StaticResource ModernButtonStyle}"/>
                                    <TextBlock Grid.Column="1" x:Name="txtSourceSavePath" Text="(No source save selected)" FontStyle="Italic" Foreground="Gray" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="Select Ship to Export:" Margin="0,5,0,5"/>
                                <ComboBox x:Name="cmbShipsToExport" Height="25" Margin="0,0,0,10" DisplayMemberPath="Sname" SelectedValuePath="Sid" IsEnabled="False"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="btnExportBlueprint" Content="Export Selected Ship Blueprint" Width="220" Style="{StaticResource ModernButtonStyle}" IsEnabled="False"/>
                                    <Button x:Name="btnDeleteSourceShip" Content="Delete Selected Ship" Width="170" Style="{StaticResource ModernButtonStyle}" Background="IndianRed" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Import Ship Blueprint" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="btnSelectBlueprintFile" Content="Select Blueprint File (.xml)..." Width="200" Style="{StaticResource ModernButtonStyle}"/>
                                    <TextBlock Grid.Column="1" x:Name="txtBlueprintFilePath" Text="(No blueprint selected)" FontStyle="Italic" Foreground="Gray" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="btnSelectTargetSave" Content="Select Target Save ('game')..." Width="200" Style="{StaticResource ModernButtonStyle}"/>
                                    <TextBlock Grid.Column="1" x:Name="txtTargetSavePath" Text="(No target save selected)" FontStyle="Italic" Foreground="Gray" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                                <CheckBox x:Name="chkImportAsBlueprint" Margin="0,0,0,10" Content="Import as Blueprint (keeps the hull plan; excludes facilities, crew, robots, and items)" IsChecked="False"/>
                                <Button x:Name="btnImportBlueprint" Content="Import Blueprint to Target Save" HorizontalAlignment="Center" Width="220" Style="{StaticResource ModernButtonStyle}" IsEnabled="False"/>
                            </StackPanel>
                        </Border>

                        <StatusBar Grid.Row="4" VerticalAlignment="Bottom" Background="#FFE0E0E0">
                            <StatusBarItem>
                                <TextBlock x:Name="txtBlueprintStatus" Text="Ready"/>
                            </StatusBarItem>
                        </StatusBar>
                    </Grid>
                </ScrollViewer>
                    </DataTemplate>
                </TabItem.ContentTemplate>
            </TabItem>
        </TabControl>
        </Grid>
    </DockPanel>
</Window>
