                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.ScheduleActivities, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          DisplayMemberPath="Value" SelectedValuePath="Key"
                                                                          SelectedValue="{Binding Activity, UpdateSourceTrigger=PropertyChanged}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                                                <Button x:Name="btnApplyCrewSchedule" Content="Apply Custom Schedule" Width="190"
                                                        Click="btnApplyCrewSchedule_Click" Style="{StaticResource ModernButtonStyle}"/>
