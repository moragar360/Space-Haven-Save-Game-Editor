<Window x:Class="SpaceHavenEditor2.SpaceHavenEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpaceHavenEditor2"
        mc:Ignorable="d"
        Title="Moragar's Space Haven Save Game Editor" Height="1300" Width="1400"
        DataContext="{Binding RelativeSource={RelativeSource Self}}" Icon="/b1a65345-8f16-4e38-87d8-0066a0f6d95c.png" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#302E2B"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#4D4943"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="Background" Value="#3C3934"/>
            <Setter Property="Foreground" Value="#F2EDE5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="-15,-15,-15,12"/>
        </Style>

        <Style x:Key="DirectionsCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="#35312C"/>
            <Setter Property="BorderBrush" Value="#6A5845"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="DirectionsExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="#E9E4DC"/>
            <Setter Property="IsExpanded" Value="False"/>
        </Style>

        <Style x:Key="DirectionsContentStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style x:Key="DirectionsTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="LineHeight" Value="18"/>
            <Setter Property="Foreground" Value="#E9E4DC"/>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#9B663B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B77B48"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#784B2B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="Gray"/>
                                <Setter Property="Foreground" Value="DarkGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#22211F"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#292825" BorderBrush="#4D4943" BorderThickness="0,0,0,1" Margin="0,0,0,0">
                                <TabPanel x:Name="HeaderPanel" Panel.ZIndex="1" Margin="5,5,5,0" IsItemsHost="True" KeyboardNavigation.TabIndex="1"/>
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost" Grid.Row="1" Margin="0,5,0,0"
                                              Content="{TemplateBinding SelectedContent}"
                                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectedContentStringFormat}"
                                              ContentTemplateSelector="{TemplateBinding SelectedContentTemplateSelector}"
                                              KeyboardNavigation.TabIndex="2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="Padding" Value="12,6"/>
                        <Setter Property="Margin" Value="2,0,2,0"/>
                        <Setter Property="Foreground" Value="#CFC5B9"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0,0,0,3"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}"
                                            Margin="{TemplateBinding Margin}"
                                            CornerRadius="3,3,0,0">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          RecognizesAccessKey="True"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FFF8EF"/>
                                <Setter Property="BorderBrush" Value="#D39A55"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Background" Value="#4B4034"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#37312B"/>
                                <Setter Property="Foreground" Value="#FFF8EF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NestedTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#292825" BorderBrush="#4D4943"
                                    BorderThickness="0,0,0,1">
                                <TabPanel x:Name="HeaderPanel" Panel.ZIndex="1" Margin="5,5,5,0"
                                          IsItemsHost="True" KeyboardNavigation.TabIndex="1"/>
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost" Grid.Row="1" Margin="0,5,0,0"
                                              Content="{TemplateBinding SelectedContent}"
                                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectedContentStringFormat}"
                                              ContentTemplateSelector="{TemplateBinding SelectedContentTemplateSelector}"
                                              KeyboardNavigation.TabIndex="2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="Padding" Value="12,6"/>
                        <Setter Property="Margin" Value="2,0,2,0"/>
                        <Setter Property="Foreground" Value="#CFC5B9"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0,0,0,3"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}"
                                            Margin="{TemplateBinding Margin}"
                                            CornerRadius="3,3,0,0">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          RecognizesAccessKey="True"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FFF8EF"/>
                                <Setter Property="BorderBrush" Value="#D39A55"/>
                                <Setter Property="Background" Value="#4B4034"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#37312B"/>
                                <Setter Property="Foreground" Value="#FFF8EF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="NavigationSectionHeaderTemplate">
            <Grid Width="209" HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding}" HorizontalAlignment="Left" TextAlignment="Left"
                           Margin="0" FontSize="11" FontWeight="Bold"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="NavigationItemHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabItem}}"
                           FontFamily="Segoe MDL2 Assets" FontSize="15" Width="24"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <Style x:Key="LeftSideTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="TabStripPlacement" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#22211F"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="245"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#1C1B19" BorderBrush="#3D3934" BorderThickness="0,0,1,0"
                                    CornerRadius="5,0,0,5">
                                <Grid>
                                    <TabPanel x:Name="HeaderPanel" IsItemsHost="True" Margin="8,8,8,8"
                                              KeyboardNavigation.TabIndex="1"/>
                                </Grid>
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost" Grid.Column="1" Margin="10,10,0,0"
                                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                              TextElement.Foreground="#E9E4DC"
                                              SnapsToDevicePixels="True"
                                              Content="{TemplateBinding SelectedContent}"
                                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                              ContentTemplateSelector="{TemplateBinding SelectedContentTemplateSelector}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="Width" Value="229"/>
                        <Setter Property="Padding" Value="15,12"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                        <Setter Property="Foreground" Value="#DED5CA"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="4,0,0,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        <Setter Property="HeaderTemplate" Value="{StaticResource NavigationItemHeaderTemplate}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                                            Margin="{TemplateBinding Margin}" CornerRadius="4">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="Tag" Value="SectionHeader">
                                <Setter Property="Padding" Value="10,18,10,6"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Foreground" Value="#BCAF9F"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FFF8EF"/>
                                <Setter Property="BorderBrush" Value="#D39A55"/>
                                <Setter Property="Background" Value="#4B4034"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#37312B"/>
                                <Setter Property="Foreground" Value="#FFF8EF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#292825"/>
            <Setter Property="Foreground" Value="#ECE7DF"/>
            <Setter Property="RowBackground" Value="#2F2D2A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#49453F"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#373430"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4D4943"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
        </Style>

        <Style x:Key="ModernDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#3C3934"/>
            <Setter Property="Foreground" Value="#F2EDE5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#575149"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#756D63"/>
            <Setter Property="Background" Value="#262522"/>
            <Setter Property="Foreground" Value="#F2EDE5"/>
            <Setter Property="CaretBrush" Value="#F2EDE5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#D39A55"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#B9AA98"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Padding" Value="5,0,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#E9E4DC"/>
            <Setter Property="BorderBrush" Value="#756D63"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#262522"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#9B663B"/>
                    <Setter Property="BorderBrush" Value="#D39A55"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#B9AA98"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="#242320"/>
            <Setter Property="Foreground" Value="#E9E4DC"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="MenuItemBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="IconHost" Grid.Column="0" ContentSource="Icon"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                      RecognizesAccessKey="True" VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <Path x:Name="SubmenuArrow" Grid.Column="2" Data="M 0 0 L 5 5 L 0 10 Z"
                                          Fill="{TemplateBinding Foreground}" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Right"
                                   HorizontalOffset="-2"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Background="#242320" BorderBrush="#575149" BorderThickness="1"
                                        Padding="3" MinWidth="175">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
                                <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#4B4034"/>
                                <Setter TargetName="MenuItemBorder" Property="BorderBrush" Value="#D39A55"/>
                                <Setter Property="Foreground" Value="#FFF8EF"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#4B4034"/>
                                <Setter Property="Foreground" Value="#FFF8EF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#80786F"/>
                                <Setter Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="#575149"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}" Height="{TemplateBinding Height}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Background="#1C1B19">
        <Menu DockPanel.Dock="Top" Background="#242320" Foreground="#E9E4DC"
              BorderBrush="#4D4943" BorderThickness="0,0,0,1"
              ItemContainerStyle="{StaticResource DarkMenuItemStyle}">
            <Menu.Resources>
                <Style TargetType="MenuItem" BasedOn="{StaticResource DarkMenuItemStyle}"/>
                <Style TargetType="Separator" BasedOn="{StaticResource DarkMenuSeparatorStyle}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#242320"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#E9E4DC"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4B4034"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFF8EF"/>
            </Menu.Resources>
            <MenuItem Header="File">
                <MenuItem Header="Open" Click="OpenFileMenu_Click" />
                <MenuItem Header="Save" Click="SaveFileMenu_Click" />
                <Separator />
                <MenuItem Header="Exit" Click="ExitMenu_Click" />
                <Separator />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Settings" Click="SettingsMenu_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Help / Instructions" Click="HelpMenu_Click" />
                <Separator/>
                <MenuItem Header="_About" Click="AboutMenu_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="51*"/>
                    <ColumnDefinition Width="8*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="5,5,0,0" Margin="0" Grid.ColumnSpan="2">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#2A2926" Offset="0"/>
                            <GradientStop Color="#49443E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Direction="270" Color="Black" Opacity="0.4" BlurRadius="5"/>
                    </Border.Effect>
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="txtMainEditorTitle" Grid.Column="0" Text="Moragar's Space Haven Save Game Editor"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="15,10"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                HorizontalAlignment="Right" Margin="0,0,12,0">
                    <TextBlock x:Name="txtUnsavedIndicator"
                               Text="Unsaved Changes"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#FFF8EF"
                               Background="#9B663B"
                               Padding="10,5"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,6,0"
                               Visibility="Collapsed">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="2" Direction="270" Color="Black" Opacity="0.5" BlurRadius="3"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="txtGameStartUnsavedIndicator"
                               Text="Game Start Unsaved"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#FFF8EF"
                               Background="#9B663B"
                               Padding="10,5"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Visibility="Collapsed"/>
                    </StackPanel>
                    </Grid>
                </Border>

                <TabControl x:Name="mainNavigationTabs" Grid.Row="1" Grid.ColumnSpan="2"
                            Style="{StaticResource LeftSideTabControlStyle}"
                            SelectionChanged="MainNavigationTabs_SelectionChanged">
                    <TabControl.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#E9E4DC"/>
                        </Style>
                        <Style TargetType="Label">
                            <Setter Property="Foreground" Value="#E9E4DC"/>
                        </Style>
                        <Style x:Key="DarkComboBoxToggleStyle" TargetType="ToggleButton">
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="ClickMode" Value="Press"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder" Background="#292825" BorderBrush="#625C54"
                                                BorderThickness="1" CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" Background="#373430" CornerRadius="0,3,3,0"/>
                                                <Path Grid.Column="1" Data="M 0 0 L 5 5 L 10 0 Z" Fill="#E9E4DC"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#D39A55"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#D39A55"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#292825"/>
                            <Setter Property="Foreground" Value="#F2EDE5"/>
                            <Setter Property="BorderBrush" Value="#625C54"/>
                            <Setter Property="Padding" Value="5,3"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <ToggleButton Style="{StaticResource DarkComboBoxToggleStyle}"
                                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                                            <ContentPresenter Margin="8,3,32,3" VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"
                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                              TextElement.Foreground="#F2EDE5"
                                                              IsHitTestVisible="False"/>
                                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                                   Focusable="False" IsOpen="{TemplateBinding IsDropDownOpen}"
                                                   PopupAnimation="Fade">
                                                <Border Background="#292825" BorderBrush="#625C54" BorderThickness="1"
                                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.55"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="#292825"/>
                            <Setter Property="Foreground" Value="#F2EDE5"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#4B4034"/>
                                                <Setter Property="Foreground" Value="#FFF8EF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#684E35"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.55"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Background" Value="#292825"/>
                            <Setter Property="Foreground" Value="#E9E4DC"/>
                            <Setter Property="BorderBrush" Value="#4D4943"/>
                        </Style>
                        <Style TargetType="ListView">
                            <Setter Property="Background" Value="#292825"/>
                            <Setter Property="Foreground" Value="#E9E4DC"/>
                            <Setter Property="BorderBrush" Value="#4D4943"/>
                        </Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Foreground" Value="#E9E4DC"/>
                        </Style>
                        <Style TargetType="RadioButton">
                            <Setter Property="Foreground" Value="#E9E4DC"/>
                        </Style>
                    </TabControl.Resources>
                    <TabItem x:Name="navGlobalHeader" Header="GLOBAL" Tag="SectionHeader" IsEnabled="False"
                             HeaderTemplate="{StaticResource NavigationSectionHeaderTemplate}"/>
                    <TabItem x:Name="navSaveSettings" Header="Save Settings" Tag="&#xE713;">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="5">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Global Save Settings" Style="{StaticResource CardTitleStyle}"/>
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,5">
                                <TextBlock Text="Player Credits:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="12"/>
                                <TextBox x:Name="txtPlayerCredits" Width="100" VerticalAlignment="Center" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,5">
                                <TextBlock Text="Prestige Points:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="12"/>
                                <TextBox x:Name="txtPrestigePoints" Width="60" VerticalAlignment="Center" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>
                            <CheckBox x:Name="chkSandbox" Content="Sandbox Mode" VerticalAlignment="Center" Margin="0,0,20,5" Style="{StaticResource ModernCheckBoxStyle}" FontSize="12"/>
                            <Button x:Name="btnUpdateGlobalSettings"
                                    Content="Update Global Settings"
                                    ToolTip="Updates the global values in memory. Use File->Save to make permanent."
                                    Width="180"
                                    VerticalAlignment="Center"
                                    Click="btnUpdateGlobalSettings_Click"
                                    Style="{StaticResource ModernButtonStyle}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem x:Name="navSaveIntegrity" Header="Save Integrity" Tag="&#xE9D9;">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource DirectionsCardStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Save Integrity Scanner" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Checks primary IDs, relationships, global schedules, known ship references, and ID counters. Critical findings block saving. Repairs are applied only when you select and approve them."
                                               TextWrapping="Wrap"/>
                                    <TextBlock x:Name="lblIntegritySummary" Text="Load a save to run the scanner."
                                               FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                                <DataGrid x:Name="dgvIntegrityFindings" AutoGenerateColumns="False" IsReadOnly="False"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          Style="{StaticResource ModernDataGridStyle}"
                                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Repair" Binding="{Binding IsSelected, Mode=TwoWay}"
                                                                Width="60" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Severity" Binding="{Binding SeverityText}" Width="85" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="135" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Affected Object" Binding="{Binding AffectedObject}" Width="170" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Finding" Binding="{Binding Description}" Width="2*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Available Repair" Binding="{Binding RepairText}" Width="180" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <WrapPanel>
                                    <Button Content="Scan Save" Width="120" Click="btnScanIntegrity_Click"
                                            Style="{StaticResource ModernButtonStyle}"/>
                                    <Button Content="Select Repairable" Width="155" Click="btnSelectRepairableIntegrity_Click"
                                            Style="{StaticResource ModernButtonStyle}"/>
                                    <Button Content="Clear Selection" Width="135" Click="btnClearIntegritySelection_Click"
                                            Style="{StaticResource ModernButtonStyle}"/>
                                    <Button Content="Apply Selected Repairs" Width="185" Click="btnApplyIntegrityRepairs_Click"
                                            Style="{StaticResource ModernButtonStyle}"/>
                                </WrapPanel>
                                <TextBlock x:Name="lblIntegrityStatus" Margin="5,8,5,0" FontStyle="Italic" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="navDifficultyRules" Header="Difficulty and World Rules" Tag="&#xE9D9;">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="5">
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Difficulty and World Rules" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Changes apply to the loaded save in memory. Existing or modded values are preserved in the dropdowns."
                                                   FontStyle="Italic" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="190"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Core Difficulty" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Grid.Row="1" Text="Mood difficulty:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbMoodDifficulty" Margin="0,4"/>
                                            <TextBlock Grid.Row="2" Text="NPC targeting:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbNpcTargeting" Margin="0,4"/>
                                            <TextBlock Grid.Row="3" Text="Quest difficulty:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbQuestDifficulty" Margin="0,4"/>
                                            <CheckBox Grid.Row="4" Grid.ColumnSpan="2" x:Name="chkRulesEnemiesEnabled" Content="Enemies enabled" Margin="0,8,0,3"/>
                                            <CheckBox Grid.Row="5" Grid.ColumnSpan="2" x:Name="chkRulesFriendsEnabled" Content="Friends enabled" Margin="0,3"/>
                                            <CheckBox Grid.Row="6" Grid.ColumnSpan="2" x:Name="chkRulesLoversEnabled" Content="Lovers enabled" Margin="0,3"/>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="205"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="World Rules" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Grid.Row="1" Text="Wear and tear:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbWearAndTear" Margin="0,4"/>
                                            <CheckBox Grid.Row="2" Grid.ColumnSpan="2" x:Name="chkRebuildingCosts" Content="Rebuilding costs enabled" Margin="0,8,0,5"/>
                                            <TextBlock Grid.Row="3" Text="Monster frequency:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbMonsterFrequency" Margin="0,4"/>
                                            <TextBlock Grid.Row="4" Text="Robot frequency:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbRobotFrequency" Margin="0,4"/>
                                            <TextBlock Grid.Row="5" Text="Solar flare frequency:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="5" Grid.Column="1" x:Name="cmbSolarFlareFrequency" Margin="0,4"/>
                                            <TextBlock Grid.Row="6" Text="Meteor frequency:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="6" Grid.Column="1" x:Name="cmbMeteorFrequency" Margin="0,4"/>
                                            <TextBlock Grid.Row="7" Text="Derelict frequency:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cmbDerelictFrequency" Margin="0,4"/>
                                            <TextBlock Grid.Row="8" Text="Derelict loot:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="8" Grid.Column="1" x:Name="cmbDerelictLoot" Margin="0,4"/>
                                            <TextBlock Grid.Row="9" Text="Asteroid / resource abundance:" VerticalAlignment="Center" Margin="0,4"/>
                                            <ComboBox Grid.Row="9" Grid.Column="1" x:Name="cmbAsteroidAbundance" Margin="0,4"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Border Style="{StaticResource CardBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="205"/>
                                            <ColumnDefinition Width="300"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Travel threat level:" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" x:Name="cmbTravelThreat" Margin="0,0,10,0"/>
                                        <Button Grid.Column="2" x:Name="btnUpdateDifficultyRules"
                                                Content="Update Difficulty and World Rules"
                                                Width="250" HorizontalAlignment="Right"
                                                IsEnabled="False"
                                                Click="btnUpdateDifficultyRules_Click"
                                                Style="{StaticResource ModernButtonStyle}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem x:Name="navStructures" Header="Structures" Tag="&#xE709;">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="5">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,5">
                    <StackPanel Orientation="Vertical">
                        <Border Background="#3C3934" Margin="-15,-15,-15,12" Padding="15,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Ships and Stations in Current Sector" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Border x:Name="pnlStationSaveBadge" Background="#C77D22" CornerRadius="4" Padding="9,3" Margin="12,0,0,0" Visibility="Collapsed">
                                    <TextBlock Text="Station Save" Foreground="White" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <CheckBox x:Name="chkShowNpcShips" Content="Show NPC and derelict ships" Margin="0,0,0,6"
                                  Checked="chkShowNpcShips_Changed" Unchecked="chkShowNpcShips_Changed"/>
                        <ComboBox x:Name="cmb_ships" Width="360" Height="30" SelectionChanged="cmb_ships_SelectionChanged" HorizontalAlignment="Left" />
                        <TextBlock x:Name="lbl_structureType" Margin="0,8,0,0" Text="Structure Type: " FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lbl_owner" Margin="0,10,0,0" Text="Owner: " FontSize="12"/>
                        <TextBlock x:Name="lbl_shipSize" Margin="0,5,0,0" Text="Size: " FontSize="12"/>
                        <TextBlock x:Name="lbl_CanvasSize" Margin="0,5,0,0" Text="Canvas Size: " FontSize="12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBox x:Name="txtStructureName" Width="240" Style="{StaticResource ModernTextBoxStyle}"/>
                            <Button x:Name="btnRenameStructure" Content="Rename" Width="100" Margin="8,0,0,0"
                                    Click="btnRenameStructure_Click" Style="{StaticResource ModernButtonStyle}"/>
                        </StackPanel>
                        <Button x:Name="btn_updateSize" Content="Update Size" Width="150" HorizontalAlignment="Left" Click="btn_updateSize_Click" Style="{StaticResource ModernButtonStyle}" Margin="0,10,0,0"/>
                        <Border x:Name="pnlStationInfo" BorderBrush="#C77D22" BorderThickness="1" CornerRadius="4"
                                Padding="10" Margin="0,10,0,0" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Station Information (read-only)" FontWeight="Bold"/>
                                <TextBlock x:Name="lblStationType" Margin="0,5,0,0"/>
                                <TextBlock x:Name="lblStationPopulation" Margin="0,3,0,0"/>
                                <TextBlock Text="Station size settings are protected because changing them can damage the save."
                                           Margin="0,6,0,0" FontStyle="Italic" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem x:Name="navResearch" Header="Research" Tag="&#xE82D;">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource DirectionsCardStyle}">
                                <Expander Header="Directions and Progress Help" Style="{StaticResource DirectionsExpanderStyle}">
                                    <StackPanel Style="{StaticResource DirectionsContentStyle}">
                                        <TextBlock Style="{StaticResource DirectionsTextStyle}">
                                            <Run Text="The Research Editor shows every technology state stored in the loaded save."/>
                                            <LineBreak/>
                                            <Run Text="Stages shows how many research stages are completed, such as 1/2."/>
                                            <LineBreak/>
                                            <Run Text="Progress Level 1/2/3 shows the three internal research-block counters saved by Space Haven for each stage. For example, 150/40/10 means 150 Level 1 blocks, 40 Level 2 blocks, and 10 Level 3 blocks have been credited."/>
                                            <LineBreak/>
                                            <Run Text="These values are raw counters, not percentages. Different technologies require different amounts, and some task-based stages do not use block counters."/>
                                            <LineBreak/>
                                            <Run Text="Complete Selected marks every stage of the chosen technology complete. Reset Selected clears its stage, block, and task progress. Complete All affects every technology."/>
                                            <LineBreak/>
                                            <Run Text="The Research Queue controls the order technologies are scheduled for research. Use File &gt; Save after making changes."
                                                 FontWeight="SemiBold" Foreground="#D39A55"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Expander>
                            </Border>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="330"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Research Technologies" Style="{StaticResource CardTitleStyle}"/>
                                        <DataGrid Grid.Row="1" x:Name="dgvResearchTechnologies" AutoGenerateColumns="False"
                                                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                                  SelectionMode="Single"
                                                  Style="{StaticResource ModernDataGridStyle}"
                                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Technology" Binding="{Binding TechnologyName}" Width="190"/>
                                                <DataGridTextColumn Header="ID" Binding="{Binding TechId}" Width="65"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="95"/>
                                                <DataGridTextColumn Header="Stages" Binding="{Binding StageSummary}" Width="65"/>
                                                <DataGridTextColumn Header="Progress (Level 1/2/3)" Binding="{Binding ProgressSummary}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                                            <Button Content="Complete Selected" Width="165" Click="btnCompleteSelectedResearch_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Reset Selected" Width="145" Click="btnResetSelectedResearch_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Complete All Research" Width="185" Click="btnCompleteAllResearch_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                        </WrapPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Research Queue" Style="{StaticResource CardTitleStyle}"/>
                                        <ListBox Grid.Row="1" x:Name="lstResearchQueue" DisplayMemberPath="DisplayName"/>
                                        <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                                            <Button Content="Move Up" Width="95" Click="btnResearchQueueUp_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Move Down" Width="95" Click="btnResearchQueueDown_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Remove" Width="95" Click="btnRemoveResearchQueue_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                        </WrapPanel>
                                        <StackPanel Grid.Row="3" Margin="0,8,0,0">
                                            <Button Content="Add Selected Technology to Queue"
                                                    Click="btnAddResearchQueue_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                            <Button Content="Clear Queue" Click="btnClearResearchQueue_Click"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                            <TextBlock Grid.Row="2" x:Name="lblResearchStatus" Margin="5,0,5,0"
                                       FontStyle="Italic" TextWrapping="Wrap"/>
                        </Grid>
                    </TabItem>

                    <TabItem x:Name="navDatalogs" Header="Datalog Unlocks" Tag="&#xE8A5;">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource DirectionsCardStyle}">
                                <Expander Header="Directions" Style="{StaticResource DirectionsExpanderStyle}">
                                    <StackPanel Style="{StaticResource DirectionsContentStyle}">
                                        <TextBlock Style="{StaticResource DirectionsTextStyle}">
                                            <Run Text="Datalogs are story and lore logs found while exploring the world, derelicts, and other locations."/>
                                            <LineBreak/>
                                            <Run Text="This page lists the datalog IDs known to the editor, plus any additional IDs already found in the loaded save."/>
                                            <LineBreak/>
                                            <Run Text="Unlock Selected makes the checked logs available in the save. Unlock All Logs unlocks every listed datalog. Reset Selected removes the checked logs from the unlocked list."/>
                                            <LineBreak/>
                                            <Run Text="Resetting a datalog does not delete world objects or cryo-log names. Use File &gt; Save after making changes."
                                                 FontWeight="SemiBold" Foreground="#D39A55"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Expander>
                            </Border>
                            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Datalog Unlocks" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Grid.Row="1"
                                               Text="Select individual logs to unlock or reset. Unlock All uses every datalog ID known to the editor."
                                               Margin="0,0,0,10" FontStyle="Italic" TextWrapping="Wrap"/>
                                    <DataGrid Grid.Row="2" x:Name="dgvDatalogUnlocks" AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              SelectionMode="Extended"
                                              Style="{StaticResource ModernDataGridStyle}"
                                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Header="Select"
                                                                    Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    Width="70"/>
                                            <DataGridTextColumn Header="Datalog" Binding="{Binding DatalogName}" Width="*"
                                                                IsReadOnly="True"/>
                                            <DataGridTextColumn Header="ID" Binding="{Binding DatalogId}" Width="90"
                                                                IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"
                                                                IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <WrapPanel Grid.Row="3" Margin="0,10,0,0">
                                        <Button Content="Select All" Width="110" Click="btnSelectAllDatalogs_Click"
                                                Style="{StaticResource ModernButtonStyle}"/>
                                        <Button Content="Clear Selection" Width="135" Click="btnClearDatalogSelection_Click"
                                                Style="{StaticResource ModernButtonStyle}"/>
                                        <Button Content="Unlock Selected" Width="150" Click="btnUnlockSelectedDatalogs_Click"
                                                Style="{StaticResource ModernButtonStyle}"/>
                                        <Button Content="Reset Selected" Width="145" Click="btnResetSelectedDatalogs_Click"
                                                Style="{StaticResource ModernButtonStyle}"/>
                                        <Button Content="Unlock All Logs" Width="145" Click="btnUnlockAllDatalogs_Click"
                                                Style="{StaticResource ModernButtonStyle}"/>
                                    </WrapPanel>
                                    <TextBlock Grid.Row="4" x:Name="lblDatalogStatus" Margin="0,8,0,0"
                                               FontStyle="Italic" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

