                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Primary weapon:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbCrewLoadoutPrimary" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Attachment:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbCrewLoadoutAttachment" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Secondary weapon:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbCrewLoadoutSecondary" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>

                                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Pocket 1:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                                <ComboBox Grid.Row="0" Grid.Column="4" x:Name="cmbCrewLoadoutPocket1" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="1" Grid.Column="3" Text="Pocket 2:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                                <ComboBox Grid.Row="1" Grid.Column="4" x:Name="cmbCrewLoadoutPocket2" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <TextBlock Grid.Row="2" Grid.Column="3" Text="Pocket 3:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                                <ComboBox Grid.Row="2" Grid.Column="4" x:Name="cmbCrewLoadoutPocket3" DisplayMemberPath="DisplayName" SelectedValuePath="ItemId"/>
                                                <CheckBox Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="2" x:Name="chkCrewBestQualityArmor"
                                                          Content="Use best available armor quality" Margin="0,6,0,4"/>
